# =============================================================================
# FluidCalendar Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# For SaaS-specific variables, see saas/.env.example
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Required)
# -----------------------------------------------------------------------------
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/fluid_calendar"

# -----------------------------------------------------------------------------
# NextAuth (Required)
# -----------------------------------------------------------------------------
# Your application URL (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Secret for signing tokens (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-secret-key-min-32-chars"

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Set to "true" to enable SaaS features (requires saas/ submodule)
# This is auto-detected if saas/ submodule is present
NEXT_PUBLIC_ENABLE_SAAS_FEATURES=false

# -----------------------------------------------------------------------------
# Calendar Integrations (Optional)
# -----------------------------------------------------------------------------
# Configure these in Settings > System, or set here

# Google Calendar
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Outlook
# Create at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# -----------------------------------------------------------------------------
# Email Service (Optional)
# -----------------------------------------------------------------------------
# Used for notifications and invitations
# Get API key at: https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com
